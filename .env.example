EXPO_PUBLIC_API_URL=http://localhost:8000
# Optional — explicit WebSocket base URL. If unset, it is derived from
# EXPO_PUBLIC_API_URL (http→ws, https→wss).
EXPO_PUBLIC_WS_URL=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_MAPS_API_KEY=
# Demo mode — when set to 1, the app runs fully offline on mock data with a
# pre-seeded demo account (no backend / network needed). Leave unset / 0 in prod.
EXPO_PUBLIC_DEMO_MODE=0
