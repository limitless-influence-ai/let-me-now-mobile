{
  "expo": {
    "name": "LMK",
    "slug": "lmk",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lmk",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kakotodev.lmk"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E53935"
      },
      "package": "com.kakotodev.lmk"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E53935"
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
